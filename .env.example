# FreeAgent OAuth Credentials
FREEAGENT_CLIENT_ID=your_client_id_here
FREEAGENT_CLIENT_SECRET=your_client_secret_here
FREEAGENT_ACCESS_TOKEN=your_access_token_here
FREEAGENT_REFRESH_TOKEN=your_refresh_token_here

# Environment
NODE_ENV=production

# Optional: maximum number of concurrent page fetches when paginating
# large list responses. Defaults to 4. Clamped to 1..16. Increase only
# if you understand FreeAgent's rate limit.
# FREEAGENT_PAGINATION_CONCURRENCY=4
